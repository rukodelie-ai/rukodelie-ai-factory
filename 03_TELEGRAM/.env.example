# Telegram Bot — получить: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Claude API — получить: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Telegram chat_id владельца — для алертов о новых заказах
ADMIN_CHAT_ID=your_telegram_chat_id

# Google Sheets — заполнить после создания таблицы
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Google сервисный аккаунт (JSON-ключ) — путь к файлу.
# Пока не задан — заказы пишутся в локальный data/orders_local.jsonl.
GOOGLE_CREDENTIALS_PATH=

# Локальный журнал заказов (по умолчанию 03_TELEGRAM/data/orders_local.jsonl)
ORDERS_LOG_PATH=

# Путь к каталогу товаров (относительно папки 03_TELEGRAM/)
CATALOG_PATH=../02_PRODUCT_DATABASE/catalog_v1.csv

# 1С OData — для интеграции каталога из 1С (опционально)
ODATA_BASE_URL=http://1c.yourserver.kz:PORT/BaseName/odata/standard.odata
ODATA_USERNAME=
ODATA_PASSWORD=
